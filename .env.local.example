# Local macOS signing + notarization credentials.
# Copy to .env.local (gitignored) and fill in. Never commit real values.

# Developer ID Application certificate, base64-encoded .p12:
#   base64 -i DeveloperIDApplication.p12 | pbcopy
CSC_LINK=
CSC_KEY_PASSWORD=

# App Store Connect API key (.p8).
# LOCAL: set APPLE_API_KEY to the .p8 file PATH and leave APPLE_API_KEY_P8 empty.
#   APPLE_API_KEY=/path/to/AuthKey_XXXXXXXXXX.p8
# Do NOT paste the .p8 contents into APPLE_API_KEY_P8 here: this file is parsed
# one line per variable, so a multi-line PEM gets truncated and notarization
# fails with "invalidPEMDocument". APPLE_API_KEY_P8 is for CI secrets only
# (GitHub preserves the newlines); the local script rejects an incomplete PEM.
APPLE_API_KEY=
APPLE_API_KEY_P8=
APPLE_API_KEY_ID=
APPLE_API_ISSUER=
APPLE_TEAM_ID=
