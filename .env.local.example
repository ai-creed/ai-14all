# Local macOS signing + notarization credentials.
# Copy to .env.local (gitignored) and fill in. Never commit real values.

# Developer ID Application certificate, base64-encoded .p12:
#   base64 -i DeveloperIDApplication.p12 | pbcopy
CSC_LINK=
CSC_KEY_PASSWORD=

# App Store Connect API key (.p8). Either point APPLE_API_KEY at the file path,
# or paste the .p8 contents into APPLE_API_KEY_P8 and the script will write it
# to a temp file for you.
APPLE_API_KEY=
APPLE_API_KEY_P8=
APPLE_API_KEY_ID=
APPLE_API_ISSUER=
APPLE_TEAM_ID=
