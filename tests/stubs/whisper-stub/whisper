#!/usr/bin/env node
// Stub whisper for ai-14all e2e. Records argv; answers `env --json`.
// ESM on purpose: the file has no extension, so Node treats it as ESM under
// the repo's "type": "module". It must not depend on CommonJS `require`.
import { appendFileSync } from "node:fs";
import { dirname } from "node:path";
import { fileURLToPath } from "node:url";

const __dirname = dirname(fileURLToPath(import.meta.url));
const argv = process.argv.slice(2);
if (process.env.WHISPER_STUB_LOG) {
	appendFileSync(
		process.env.WHISPER_STUB_LOG,
		`${JSON.stringify({ argv, cwd: process.cwd() })}\n`,
	);
}

if (argv[0] === "env" && argv.includes("--json")) {
	// Opt-in evaluator block: a test that sets WHISPER_STUB_EVALUATOR to a JSON
	// string gets it echoed through as `evaluator`; everyone else emits no field,
	// matching an older whisper (so the panel shows no warning).
	const evaluatorRaw = process.env.WHISPER_STUB_EVALUATOR;
	process.stdout.write(
		JSON.stringify({
			engineVersion: "0.6.0-stub",
			installPath: __dirname,
			stateRoot: process.env.WHISPER_STUB_STATE_ROOT ?? "/tmp",
			dbSchemaVersion: 6,
			protocolVersion: "1",
			...(evaluatorRaw ? { evaluator: JSON.parse(evaluatorRaw) } : {}),
		}),
	);
	process.exit(0);
}
// All control commands succeed silently in the stub.
process.exit(0);
