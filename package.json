{
	"name": "ai-14all",
	"version": "1.5.0",
	"private": true,
	"description": "Mission-control desktop app for running AI coding agents in parallel across Git worktrees",
	"author": "Vu Phan <vu.phan.se@gmail.com>",
	"license": "FSL-1.1-ALv2",
	"homepage": "https://ai-creed.dev/projects/ai-14all/",
	"packageManager": "pnpm@10.33.0",
	"type": "module",
	"main": "out/main/index.js",
	"scripts": {
		"predev": "electron-rebuild -f -w better-sqlite3 || true",
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"preview": "electron-vite preview",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --check .",
		"format:write": "prettier --write .",
		"postinstall": "node scripts/ensure-node-pty-spawn-helper.mjs",
		"typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.test.json",
		"pretest": "node scripts/rebuild-better-sqlite3-host.mjs || true",
		"test": "vitest run --passWithNoTests",
		"test:perf": "vitest run --config vitest.perf.config.ts",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"pretest:e2e": "electron-rebuild -f -w better-sqlite3 || true",
		"test:e2e": "electron-vite build && playwright test",
		"posttest:e2e": "node scripts/rebuild-better-sqlite3-host.mjs || true",
		"test:all": "pnpm test && pnpm test:e2e",
		"package:mac": "pnpm build && electron-builder --mac --publish never",
		"package:mac:signed": "node scripts/package-mac-signed.mjs",
		"package:win": "pnpm build && electron-builder --win zip --publish never",
		"release:beta": "node scripts/release-beta.mjs",
		"release:stable": "node scripts/release-stable.mjs",
		"diag:attention": "node scripts/dump-attention-log.mjs",
		"fixture:pty": "tsx --tsconfig scripts/tsconfig.tsx.json scripts/generate-pty-fixture.ts"
	},
	"dependencies": {
		"@ai-creed/command-contract": "file:vendor/ai-creed-command-contract-0.1.0-alpha.4.tgz",
		"@fontsource-variable/hanken-grotesk": "^5.2.8",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@monaco-editor/react": "^4.7.0",
		"@radix-ui/react-context-menu": "^2.2.16",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-scroll-area": "^1.2.0",
		"@radix-ui/react-separator": "^1.1.0",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-tabs": "^1.1.0",
		"@radix-ui/react-tooltip": "^1.2.0",
		"@tanstack/react-virtual": "^3.13.23",
		"@xavier/xbp": "file:vendor/xavier-xbp-0.1.0-alpha.0.tgz",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/headless": "6.0.0",
		"better-sqlite3": "^12.10.0",
		"chokidar": "^3.6.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"electron-updater": "^6.8.3",
		"highlight.js": "^11.11.1",
		"js-yaml": "^4.1.1",
		"libsodium-wrappers": "^0.7.15",
		"lucide-react": "^1.17.0",
		"monaco-editor": "^0.55.1",
		"node-pty": "^1.1.0",
		"qrcode": "^1.5.4",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0",
		"rehype-highlight": "^7.0.2",
		"remark-gfm": "^4.0.1",
		"smol-toml": "^1.6.1",
		"tailwind-merge": "^3.6.0",
		"xterm": "^5.3.0",
		"xterm-addon-search": "^0.13.0",
		"zod": "^4.3.6"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"electron",
			"esbuild",
			"node-pty",
			"better-sqlite3"
		],
		"overrides": {
			"@ai-creed/command-contract": "file:vendor/ai-creed-command-contract-0.1.0-alpha.4.tgz"
		}
	},
	"devDependencies": {
		"@electron/rebuild": "^4.0.4",
		"@eslint/js": "^9.25.1",
		"@playwright/test": "^1.59.1",
		"@stylistic/eslint-plugin": "^2.13.0",
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/better-sqlite3": "^7.6.13",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.5.0",
		"@types/qrcode": "^1.5.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/ws": "^8.18.1",
		"@vitejs/plugin-react": "^4.7.0",
		"builder-util": "^26.15.0",
		"electron": "^41.1.1",
		"electron-builder": "^26.15.2",
		"electron-vite": "^5.0.0",
		"eslint": "^9.25.1",
		"eslint-plugin-react-hooks": "^5.2.0",
		"globals": "^15.15.0",
		"jsdom": "^29.0.1",
		"prettier": "^3.5.3",
		"shakespii": "^0.3.1",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.30.1",
		"vite": "^6.4.1",
		"vitest": "^4.1.2",
		"ws": "^8.21.0"
	}
}
